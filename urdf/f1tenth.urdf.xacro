<?xml version="1.0"?>

<!-- 
  URDF for F1Tenth Gazebo simulation.
    - body_mass:  18.0 kg  → 3.5 kg   (realistic 1/10 scale car weight)
    - wheel_mass: 0.5 kg   → 0.1 kg   (realistic RC tire weight)
    - hinge_mass: 0.5 kg   → 0.1 kg   (lightweight steering knuckle)
    - Body inertia recalculated for 3.5 kg solid box
    - Wheel inertia recalculated for 0.1 kg cylinder
    - Steering hinge limits: ±0.5 rad → ±0.31 rad (from VESC servo clamp)
    - Steering hinge velocity: 5.0 → 3.2 rad/s (from throttle_interpolator max_servo_speed)
    - Tire friction: mu1 1.5→0.8, mu2 2.5→1.0 (indoor smooth surface)
    - Contact stiffness: kp 500000→100000 (less rigid tire contact)
    - Laser position: 0.275→0.27 m (matches static_transform_publisher in launch)
    - max_steer: 0.5→0.31 rad (matches VESC-derived steering limit)
    - max_wheel_torque: 100→20 Nm (matches 2.5 m/s² accel limit at 3.5 kg)
    - Steering PID: reduced for lighter mass to prevent overshoot
    - Velocity PID: reduced for lighter mass
-->

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="racecar">

  <!-- ================================================================== -->
  <!-- Geometric properties                                                -->
  <!-- ================================================================== -->
  <xacro:property name="wheelbase" value="0.25" />
  <xacro:property name="width" value="0.2032" />
  <xacro:property name="height" value="0.1" />
  <xacro:property name="ground_offset" value="0.02" />
  <xacro:property name="wheel_radius" value="0.0508" />
  <xacro:property name="wheel_length" value="0.0381" />
  <xacro:property name="car_name" value="ego_racecar" />

  <!-- laser position from static_transform_publisher: 0.27m forward, 0.11m up -->
  <xacro:property name="laser_distance_from_base_link" value="0.27" />
  <xacro:property name="laser_height" value="0.05" />
  <xacro:property name="laser_radius" value="0.026" />

  <!-- ================================================================== -->
  <!-- Mass properties                                                     -->
  <!--   Real F1Tenth car: ~3.2-3.8 kg total (chassis + battery + compute  -->
  <!--   + LiDAR + VESC). Using 3.5 kg as body mass.                      -->
  <!--   RC tires: ~80-120g each. Using 0.1 kg.                           -->
  <!-- ================================================================== -->
  <xacro:property name="body_mass" value="3.5" />
  <xacro:property name="wheel_mass" value="0.1" />
  <xacro:property name="hinge_mass" value="0.1" />

  <!-- Steering limits derived from VESC config                 -->
  <!--   servo range [0.15, 0.85], gain=-1.2135, offset=0.5304            -->
  <!--   max angle = (0.85 - 0.5304) / 1.2135 ≈ 0.264 rad               -->
  <!--   min angle = (0.15 - 0.5304) / 1.2135 ≈ -0.314 rad              -->
  <!--   Using ±0.31 as symmetric approximation                           -->
  <xacro:property name="max_steering_angle" value="0.31" />

  <!-- Steering velocity from throttle_interpolator config      -->
  <xacro:property name="max_steering_velocity" value="3.2" />

  <!-- ================================================================== -->
  <!-- Body inertia at 3.5 kg (solid box: 0.25 x 0.2032 x 0.1)-->
  <!--   ixx = (1/12)*3.5*(0.2032² + 0.1²)  = 0.0150                     -->
  <!--   iyy = (1/12)*3.5*(0.25²   + 0.1²)  = 0.0347                     -->
  <!--   izz = (1/12)*3.5*(0.25²   + 0.2032²)= 0.0439                    -->
  <!-- ================================================================== -->

  <!-- ================================================================== -->
  <!-- Wheel inertia at 0.1 kg (cylinder r=0.0508, h=0.0381)   -->
  <!--   ixx = iyy = (1/12)*0.1*(3*0.0508² + 0.0381²) = 0.0000766        -->
  <!--   izz = (1/2)*0.1*0.0508²                       = 0.000129         -->
  <!-- ================================================================== -->

  <!-- ================================================================== -->
  <!-- Materials                                                           -->
  <!-- ================================================================== -->
  <material name="black">
    <color rgba="0.2 0.2 0.2 1."/>
  </material>

  <material name="blue">
    <color rgba="0.3 0.57 1. 1."/>
  </material>

  <!-- ================================================================== -->
  <!-- Base link (chassis)                                                 -->
  <!-- ================================================================== -->
  <link name="${car_name}/base_link">
    <visual>
      <origin xyz="${wheelbase/2} 0 ${ground_offset+height/2}"/>
      <geometry>
        <box size="${wheelbase} ${width} ${height}"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="${wheelbase/2} 0 ${ground_offset+height/2}"/>
      <geometry>
        <box size="${wheelbase * 0.8} ${width * 0.8} ${height}"/>
      </geometry>
    </collision>

    <!-- mass and inertia for 3.5 kg -->
    <inertial>
      <origin xyz="${wheelbase/2} 0 ${ground_offset+height/2}"/>
      <mass value="${body_mass}"/>
      <inertia ixx="0.0150" ixy="0.0" ixz="0.0"
               iyy="0.0347" iyz="0.0"
               izz="0.0439"/>
    </inertial>
  </link>

  <gazebo reference="${car_name}/base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- ================================================================== -->
  <!-- LiDAR (Hokuyo URG)                                                 -->
  <!-- ================================================================== -->
  <joint name="base_to_laser_model" type="fixed">
    <parent link="${car_name}/base_link"/>
    <child link="${car_name}/laser_model"/>
    <!-- x=0.27 to match static_transform_publisher in launch file -->
    <origin xyz="${laser_distance_from_base_link} 0 ${ground_offset+height+(laser_height/2)}"/>
  </joint>

  <link name="${car_name}/laser_model">
    <visual>
      <geometry>
        <cylinder radius="${laser_radius}" length="${laser_height}"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- ================================================================== -->
  <!-- Back left wheel                                                     -->
  <!-- ================================================================== -->
  <joint name="base_to_back_left_wheel" type="continuous">
    <parent link="${car_name}/base_link"/>
    <child link="${car_name}/back_left_wheel"/>
    <origin xyz="0 ${(wheel_length+width)/2} ${wheel_radius}"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" velocity="100.0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="${car_name}/back_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="black"/>
      <origin rpy="${pi/2} 0 0"/>
    </visual>

    <collision>
      <origin rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>

    <!-- wheel inertia at 0.1 kg -->
    <inertial>
      <origin rpy="${pi/2} 0 0"/>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.0000766" ixy="0.0" ixz="0.0"
               iyy="0.0000766" iyz="0.0"
               izz="0.000129"/>
    </inertial>
  </link>

  <!-- tire friction for indoor smooth surface -->
  <gazebo reference="${car_name}/back_left_wheel">
    <material>Gazebo/Black</material>
    <mu1>0.8</mu1>
    <mu2>1.0</mu2>
    <kp>100000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

  <!-- ================================================================== -->
  <!-- Back right wheel                                                    -->
  <!-- ================================================================== -->
  <joint name="base_to_back_right_wheel" type="continuous">
    <parent link="${car_name}/base_link"/>
    <child link="${car_name}/back_right_wheel"/>
    <origin xyz="0 ${-(wheel_length+width)/2} ${wheel_radius}"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" velocity="100.0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="${car_name}/back_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="black"/>
      <origin rpy="${pi/2} 0 0"/>
    </visual>

    <collision>
      <origin rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>

    <!-- wheel inertia at 0.1 kg -->
    <inertial>
      <origin rpy="${pi/2} 0 0"/>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.0000766" ixy="0.0" ixz="0.0"
               iyy="0.0000766" iyz="0.0"
               izz="0.000129"/>
    </inertial>
  </link>

  <!-- tire friction for indoor smooth surface -->
  <gazebo reference="${car_name}/back_right_wheel">
    <material>Gazebo/Black</material>
    <mu1>0.8</mu1>
    <mu2>1.0</mu2>
    <kp>100000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

  <!-- ================================================================== -->
  <!-- Front left steering hinge + wheel                                   -->
  <!-- ================================================================== -->

  <!-- steering limits from VESC servo config, velocity from throttle_interpolator -->
  <joint name="base_to_front_left_hinge" type="revolute">
    <parent link="${car_name}/base_link"/>
    <child link="${car_name}/front_left_hinge"/>
    <origin xyz="${wheelbase} ${(wheel_length+width)/2} ${wheel_radius}"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${max_steering_angle}" upper="${max_steering_angle}" effort="10.0" velocity="${max_steering_velocity}"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <link name="${car_name}/front_left_hinge">
    <inertial>
      <mass value="${hinge_mass}"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="front_left_hinge_to_wheel" type="continuous">
    <parent link="${car_name}/front_left_hinge"/>
    <child link="${car_name}/front_left_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" velocity="100.0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="${car_name}/front_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="black"/>
      <origin rpy="${pi/2} 0 0"/>
    </visual>

    <collision>
      <origin rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>

    <!-- wheel inertia at 0.1 kg -->
    <inertial>
      <origin rpy="${pi/2} 0 0"/>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.0000766" ixy="0.0" ixz="0.0"
               iyy="0.0000766" iyz="0.0"
               izz="0.000129"/>
    </inertial>
  </link>

  <!-- tire friction for indoor smooth surface -->
  <gazebo reference="${car_name}/front_left_wheel">
    <material>Gazebo/Black</material>
    <mu1>0.8</mu1>
    <mu2>1.0</mu2>
    <kp>100000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

  <!-- ================================================================== -->
  <!-- Front right steering hinge + wheel                                  -->
  <!-- ================================================================== -->

  <!-- steering limits from VESC servo config, velocity from throttle_interpolator -->
  <joint name="base_to_front_right_hinge" type="revolute">
    <parent link="${car_name}/base_link"/>
    <child link="${car_name}/front_right_hinge"/>
    <origin xyz="${wheelbase} ${-(wheel_length+width)/2} ${wheel_radius}"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${max_steering_angle}" upper="${max_steering_angle}" effort="10.0" velocity="${max_steering_velocity}"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <link name="${car_name}/front_right_hinge">
    <inertial>
      <mass value="${hinge_mass}"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="front_right_hinge_to_wheel" type="continuous">
    <parent link="${car_name}/front_right_hinge"/>
    <child link="${car_name}/front_right_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" velocity="100.0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="${car_name}/front_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="black"/>
      <origin rpy="${pi/2} 0 0"/>
    </visual>

    <collision>
      <origin rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>

    <!-- wheel inertia at 0.1 kg -->
    <inertial>
      <origin rpy="${pi/2} 0 0"/>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.0000766" ixy="0.0" ixz="0.0"
               iyy="0.0000766" iyz="0.0"
               izz="0.000129"/>
    </inertial>
  </link>

  <!-- tire friction for indoor smooth surface -->
  <gazebo reference="${car_name}/front_right_wheel">
    <material>Gazebo/Black</material>
    <mu1>0.6</mu1>
    <mu2>0.8</mu2>
    <kp>100000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

  <!-- ================================================================== -->
  <!-- Intel RealSense D435i Camera                                        -->
  <!-- ================================================================== -->
  <xacro:include filename="$(find realsense2_description)/urdf/_d435i.urdf.xacro" />

  <!-- TODO: Measure actual camera mount position on your car and update xyz -->
  <xacro:sensor_d435i parent="${car_name}/base_link" name="camera">
    <origin xyz="0.35 0.0 0.15" rpy="0 0 0"/>
  </xacro:sensor_d435i>

  <gazebo reference="camera_link">
    <sensor type="depth" name="camera">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <camera name="camera">
        <horizontal_fov>1.518</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>

      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/</namespace>
        </ros>
        <camera_name>camera</camera_name>
        <image_topic_name>color/image_raw</image_topic_name>
        <camera_info_topic_name>color/camera_info</camera_info_topic_name>
        <depth_image_topic_name>depth/image_rect_raw</depth_image_topic_name>
        <depth_image_camera_info_topic_name>depth/camera_info</depth_image_camera_info_topic_name>
        <point_cloud_topic_name>points</point_cloud_topic_name>
        <frame_name>camera_depth_optical_frame</frame_name>
        <min_depth>0.1</min_depth>
        <max_depth>10.0</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ================================================================== -->
  <!-- Ackermann drive plugin                                              -->
  <!-- ================================================================== -->
  <gazebo>
    <plugin name="gazebo_ros_ackermann_drive" filename="libgazebo_ros_ackermann_drive.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>50.0</update_rate>

      <left_steering_joint>base_to_front_left_hinge</left_steering_joint>
      <right_steering_joint>base_to_front_right_hinge</right_steering_joint>

      <rear_left_joint>base_to_back_left_wheel</rear_left_joint>
      <rear_right_joint>base_to_back_right_wheel</rear_right_joint>

      <front_left_joint>front_left_hinge_to_wheel</front_left_joint>
      <front_right_joint>front_right_hinge_to_wheel</front_right_joint>

      <wheel_separation>${width + wheel_length}</wheel_separation>
      <wheel_base>${wheelbase}</wheel_base>

      <wheel_radius>${wheel_radius}</wheel_radius>
      <wheel_diameter>${wheel_radius * 2}</wheel_diameter>

      <!-- steering limit from VESC servo config -->
      <max_steer>${max_steering_angle}</max_steer>
      <max_speed>5.0</max_speed>
      <max_wheel_torque>20.0</max_wheel_torque>

      <!-- PID gains -->
      <linear_velocity_pid_gain>3.0 0.3 0.03</linear_velocity_pid_gain>
      <left_steering_pid_gain>12.0 1.0 0.15</left_steering_pid_gain>
      <right_steering_pid_gain>12.0 1.0 0.15</right_steering_pid_gain>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>${car_name}/base_link</robot_base_frame>
    </plugin>
  </gazebo>

</robot>